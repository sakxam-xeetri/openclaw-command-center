# OpenClaw Command Center — Environment Configuration
# Copy this file to .env and fill in your values:  cp .env.example .env

# Server port (default: 3000)
PORT=3000

# OpenClaw Gateway connection
GATEWAY_URL=ws://127.0.0.1:18789
GATEWAY_TOKEN=

# Demo mode — set to false when connected to a real OpenClaw gateway
# In demo mode, the UI runs fully without a gateway or agents
DEMO_MODE=true

# OpenAI API key — required for voice (Whisper STT + TTS)
# Leave blank to disable voice features
OPENAI_API_KEY=

# Weather widget location (City,Region,Country — used by wttr.in)
WEATHER_LOCATION=Kingston,Ontario,Canada
